{
  "name": "portfolio-website",
  "version": "1.0.0",
  "private": true,
  "description": "Sakiina's portfolio website - Hugo + TailwindCSS",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "alpinejs": "^3.15.12",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.14",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14"
  },
  "scripts": {
    "dev": "npm run build:css:dev && hugo server --disableFastRender --noHTTPCache",
    "dev:watch": "concurrently \"npm run css:watch\" \"npm run hugo:watch\"",
    "css:watch": "vite build --mode development --watch",
    "hugo:watch": "hugo server --disableFastRender --noHTTPCache",
    "build:css": "vite build --mode production",
    "build:css:dev": "vite build --mode development --no-watch",
    "build": "npm run build:css && hugo --minify --gc --cleanDestinationDir"
  },
  "license": "MIT"
}
